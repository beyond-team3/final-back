### 공통 헬퍼 요청
### 사용 순서
### 1) _env.http 로그인 완료 후 실행
### 2) 각 리스트 API에서 첫 번째 ID를 전역 변수로 저장
### 3) 도메인 파일에서 저장된 변수 재사용

@baseUrl = http://localhost:8080

### 1) 주문 목록에서 orderId 추출 (CLIENT)
GET {{baseUrl}}/api/v1/orders
Authorization: Bearer {{client1AccessToken}}

> {%
client.test("get orders success", function () {
  client.assert(response.status === 200, "status must be 200");
});
if (response.body && response.body.result === "SUCCESS" && response.body.data && response.body.data.length > 0) {
  client.global.set("orderId", response.body.data[0].orderId);
}
%}

### 2) 명세서 목록에서 statementId 추출 (SALES_REP)
GET {{baseUrl}}/api/v1/statements
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("get statements success", function () {
  client.assert(response.status === 200, "status must be 200");
});
if (response.body && response.body.result === "SUCCESS" && response.body.data && response.body.data.length > 0) {
  client.global.set("statementId", response.body.data[0].statementId);
}
%}

### 3) 청구서 목록에서 invoiceId / 상태별 invoiceId 추출 (SALES_REP)
GET {{baseUrl}}/api/v1/invoices
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("get invoices success", function () {
  client.assert(response.status === 200, "status must be 200");
});
if (response.body && response.body.result === "SUCCESS" && response.body.data && response.body.data.length > 0) {
  client.global.set("invoiceId", response.body.data[0].invoiceId);
  for (const inv of response.body.data) {
    if (inv.status === "DRAFT" && !client.global.get("invoiceDraftId")) {
      client.global.set("invoiceDraftId", inv.invoiceId);
    }
    if (inv.status === "PUBLISHED" && !client.global.get("invoicePublishedId")) {
      client.global.set("invoicePublishedId", inv.invoiceId);
    }
  }
}
%}

### 4) 결제 목록에서 paymentId 추출 (SALES_REP)
GET {{baseUrl}}/api/v1/payments
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("get payments success", function () {
  client.assert(response.status === 200, "status must be 200");
});
if (response.body && response.body.result === "SUCCESS" && response.body.data && response.body.data.length > 0) {
  client.global.set("paymentId", response.body.data[0].paymentId);
}
%}

### 5) 딜 목록에서 dealId/clientId/docType/refId 추출 (SALES_REP)
GET {{baseUrl}}/api/v1/deals?page=0&size=20&sort=lastActivityAt,desc
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("get deals success", function () {
  client.assert(response.status === 200, "status must be 200");
});
if (response.body && response.body.result === "SUCCESS" && response.body.data && response.body.data.content && response.body.data.content.length > 0) {
  const first = response.body.data.content[0];
  if (first.dealId) client.global.set("dealId", first.dealId);
  if (first.clientId) client.global.set("dealClientId", first.clientId);
  if (first.latestDocType) client.global.set("dealLatestDocType", first.latestDocType);
  if (first.latestRefId) client.global.set("dealLatestRefId", first.latestRefId);
}
%}
