### Order API Test
### 실행 순서
### 1) _env.http 로그인 3개(CLIENT #1 / SALES_REP / ADMIN) 실행
### 2) 아래 [SETUP] SQL로 유효기간 내 계약 헤더/상세 생성 후 testContractId/testContractDetailId 값 세팅
### 3) 필요 시 _common.http 실행
### 4) 아래 SUCCESS 시나리오 실행 (create -> get -> confirm -> list)
### 5) 아래 FAILURE 시나리오 실행

@baseUrl = http://localhost:8080
@testContractId = 6
@testContractDetailId = 12
@missingOrderId = 99999991

### [SETUP] 더미 계약 생성 SQL (DB에서 실행 후 결과 ID를 위 변수에 반영)
### START TRANSACTION;
### SET @client_id := (SELECT client_id FROM tbl_client ORDER BY client_id LIMIT 1);
### SET @author_id := (SELECT employee_id FROM tbl_employee ORDER BY employee_id LIMIT 1);
### SET @today := CURDATE();
### SET @start_date := DATE_SUB(@today, INTERVAL 1 DAY);
### SET @end_date := DATE_ADD(@today, INTERVAL 30 DAY);
### SET @contract_code := CONCAT('CNT-HTTP-', DATE_FORMAT(@today, '%Y%m%d'), '-', UNIX_TIMESTAMP());
### INSERT INTO tbl_contract_header (contract_code, quo_id, client_id, author_id, status, total_amount, start_date, end_date, billing_cycle, special_terms, memo, issue_date, updated_at)
### SELECT @contract_code, NULL, @client_id, @author_id, 'ACTIVE_CONTRACT', 0, @start_date, @end_date, 'MONTHLY', 'HTTP TEST TERMS', 'HTTP_TEST_CONTRACT', NOW(), NOW()
### WHERE @client_id IS NOT NULL AND @author_id IS NOT NULL;
### SET @header_id := LAST_INSERT_ID();
### INSERT INTO tbl_contract_detail (cnt_id, product_id, product_category, product_name, total_quantity, unit, unit_price, amount)
### VALUES (@header_id, NULL, '채소', '테스트 토마토', 100, 'BOX', 120000, 12000000),
###        (@header_id, NULL, '채소', '테스트 오이',   50, 'BOX',  80000,  4000000);
### UPDATE tbl_contract_header h
### SET h.total_amount = (SELECT COALESCE(SUM(d.amount), 0) FROM tbl_contract_detail d WHERE d.cnt_id = @header_id)
### WHERE h.cnt_id = @header_id;
### COMMIT;
### SELECT h.cnt_id AS testContractId, d.cnt_detail_id AS testContractDetailId
### FROM tbl_contract_header h JOIN tbl_contract_detail d ON d.cnt_id = h.cnt_id
### WHERE h.cnt_id = @header_id ORDER BY d.cnt_detail_id;

### ============================================================
### SUCCESS FLOW
### ============================================================

### [S1] 주문 생성 (CLIENT #1)
POST {{baseUrl}}/api/v1/orders
Authorization: Bearer {{client1AccessToken}}
Content-Type: application/json

{
  "headerId": {{testContractId}},
  "shippingName": "HTTP Client User",
  "shippingPhone": "010-1111-2222",
  "shippingAddress": "Seoul",
  "shippingAddressDetail": "101-1001",
  "deliveryRequest": "문 앞에 놔주세요",
  "items": [
    {
      "contractDetailId": {{testContractDetailId}},
      "quantity": 1
    }
  ]
}

> {%
client.test("order create success", function () {
  client.assert(response.status === 201, "status must be 201");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
if (response.body && response.body.data) {
  client.global.set("orderId", response.body.data.orderId);
  client.global.set("orderOwnerClientOrderId", response.body.data.orderId);
}
%}

### [S2] 주문 단건 조회
GET {{baseUrl}}/api/v1/orders/{{orderId}}
Authorization: Bearer {{client1AccessToken}}

> {%
client.test("order get success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### [S3] 주문 확정 (PENDING -> CONFIRMED)
PATCH {{baseUrl}}/api/v1/orders/{{orderId}}/confirm
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("order confirm success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
  client.assert(response.body.data.status === "CONFIRMED", "status must be CONFIRMED");
});
%}

### [S4] 주문 목록 조회
GET {{baseUrl}}/api/v1/orders
Authorization: Bearer {{client1AccessToken}}

> {%
client.test("order list success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### ============================================================
### FAILURE FLOW (ErrorType / ErrorCode 검증)
### ApiResult.error 구조: { result:"ERROR", error:{ code, message, data } }
### ============================================================

### [F1] Validation/Type 오류: path variable 타입 불일치
### 기대: ErrorType.INVALID_TYPE_VALUE -> ErrorCode.C004
GET {{baseUrl}}/api/v1/orders/not-a-number
Authorization: Bearer {{client1AccessToken}}

> {%
client.test("order path type mismatch -> C004", function () {
  client.assert(response.status === 400, "status must be 400");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "C004", "error.code must be C004");
});
%}

### [F2] 인증 실패: 토큰 없음
### 기대: ErrorType.UNAUTHORIZED -> ErrorCode.A001
GET {{baseUrl}}/api/v1/orders

> {%
client.test("order unauthorized -> A001", function () {
  client.assert(response.status === 401, "status must be 401");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "A001", "error.code must be A001");
});
%}

### [F3] 리소스 없음: 존재하지 않는 주문 ID
### 기대: ErrorType.ORDER_NOT_FOUND -> ErrorCode.O001
GET {{baseUrl}}/api/v1/orders/{{missingOrderId}}
Authorization: Bearer {{client1AccessToken}}

> {%
client.test("order not found -> O001", function () {
  client.assert(response.status === 404, "status must be 404");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "O001", "error.code must be O001");
});
%}

### [F4] 수량 검증 실패: 계약 잔여 수량 초과
### 기대: ErrorType.ORDER_QUANTITY_EXCEEDED -> ErrorCode.O002
POST {{baseUrl}}/api/v1/orders
Authorization: Bearer {{client1AccessToken}}
Content-Type: application/json

{
  "headerId": {{testContractId}},
  "shippingName": "Over Quantity",
  "shippingPhone": "010-9999-9999",
  "shippingAddress": "Seoul",
  "shippingAddressDetail": "201-1201",
  "deliveryRequest": "-",
  "items": [
    {
      "contractDetailId": {{testContractDetailId}},
      "quantity": 999999999
    }
  ]
}

> {%
client.test("order quantity exceeded -> O002", function () {
  client.assert(response.status === 400, "status must be 400");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "O002", "error.code must be O002");
});
%}

### [F5] 권한 실패: SALES_REP가 주문 취소 시도(거래처 전용 로직)
### 기대: ErrorType.ACCESS_DENIED -> ErrorCode.A002
PATCH {{baseUrl}}/api/v1/orders/{{orderOwnerClientOrderId}}/cancel
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("order cancel by sales rep denied -> A002", function () {
  client.assert(response.status === 403, "status must be 403");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "A002", "error.code must be A002");
});
%}

### [F6] 상태 전이 위반: 이미 CONFIRMED 주문 재확정
### 기대: ErrorType.ORDER_ALREADY_CONFIRMED -> ErrorCode.O007
PATCH {{baseUrl}}/api/v1/orders/{{orderId}}/confirm
Authorization: Bearer {{salesAccessToken}}

> {%
client.test("order confirm twice -> O007", function () {
  client.assert(response.status === 400, "status must be 400");
  client.assert(response.body.result === "ERROR", "result must be ERROR");
  client.assert(response.body.error.code === "O007", "error.code must be O007");
});
%}
