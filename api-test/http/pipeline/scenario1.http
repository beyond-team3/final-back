### [2-1] QUO 생성 (SALES_REP)
POST {{baseUrl}}/api/v1/quotations
Authorization: Bearer {{salesToken}}
Content-Type: application/json

{
  "requestId": {{rfqId}},
  "clientId": {{clientId}},
  "items": [
    {
      "productId": {{watermelonProductId}},
      "productName": "프리미엄 수박 5kg",
      "productCategory": "수박",
      "quantity": 20,
      "unit": "BOX",
      "unitPrice": 35000
    },
    {
      "productId": {{melonProductId}},
      "productName": "고당도 참외 3kg",
      "productCategory": "참외",
      "quantity": 15,
      "unit": "BOX",
      "unitPrice": 22000
    }
  ],
  "memo": "시나리오1 견적서"
}

> {%
client.test("QUO create success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### [2-2] QUO ID 조회
GET {{baseUrl}}/api/v1/deals?clientId={{clientId}}&latestDocType=QUO&page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("deal list for QUO success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const deal = (response.body.data.content || []).find((item) => item.dealId === Number(client.global.get("dealId")));
client.assert(!!deal, "deal for quotation must exist");
client.global.set("quoId", deal.latestRefId);
%}

### [2-3] QUO 상세 조회
GET {{baseUrl}}/api/v1/quotations/{{quoId}}
Authorization: Bearer {{salesToken}}

> {%
client.test("quotation detail success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.data.status === "WAITING_ADMIN", "quotation status must be WAITING_ADMIN");
});
client.global.set("quoCode", response.body.data.quotationCode);
%}

### [2-4] DealLog 조회 - QUO 생성 확인
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=50&sort=actionAt,asc
Authorization: Bearer {{salesToken}}

> {%
client.test("deal log contains QUO create", function () {
  client.assert(response.status === 200, "status must be 200");
  const logs = response.body.data.content || [];
  client.assert(logs.some((log) => log.docType === "QUO" && log.refId === Number(client.global.get("quoId")) && log.actionType === "CREATE"), "QUO CREATE log must exist");
});
%}

### [2-5] QUO 승인 요청 제출
POST {{baseUrl}}/api/v1/approvals
Authorization: Bearer {{salesToken}}
Content-Type: application/json

{
  "dealType": "QUO",
  "targetId": {{quoId}},
  "clientIdSnapshot": {{clientId}},
  "targetCodeSnapshot": "{{quoCode}}"
}

> {%
client.test("quotation approval request success", function () {
  client.assert(response.status === 201, "status must be 201");
  client.assert(response.body.data.status === "PENDING", "approval status must be PENDING");
});
client.global.set("quoApprovalId", response.body.data.approvalId);
%}

### [2-6] QUO 승인 상세 조회 - step ID 확보
GET {{baseUrl}}/api/v1/approvals/{{quoApprovalId}}
Authorization: Bearer {{salesToken}}

> {%
client.test("quotation approval detail success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const steps = response.body.data.steps || [];
const adminStep = steps.find((step) => step.actorType === "ADMIN");
const clientStep = steps.find((step) => step.actorType === "CLIENT");
client.assert(!!adminStep && !!clientStep, "quotation approval steps must exist");
client.global.set("quoAdminStepId", adminStep.stepId);
client.global.set("quoClientStepId", clientStep.stepId);
%}

### [2-7] Notification 조회 (ADMIN) - 승인 요청 알림 확인
GET {{baseUrl}}/api/v1/notifications?page=0&size=20
Authorization: Bearer {{adminToken}}

> {%
client.test("admin notification for approval request exists", function () {
  client.assert(response.status === 200, "status must be 200");
  const items = response.body.data.content || [];
  client.assert(items.some((item) => item.type === "APPROVAL_REQUESTED"), "APPROVAL_REQUESTED notification must exist");
});
%}

### [2-8] QUO 관리자 승인
POST {{baseUrl}}/api/v1/approvals/{{quoApprovalId}}/steps/{{quoAdminStepId}}/decision
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "decision": "APPROVE",
  "reason": "관리자 승인"
}

> {%
client.test("quotation admin approval success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.data.status === "PENDING", "approval request stays pending until client step");
});
%}

### [2-9] QUO 상태 확인 - WAITING_CLIENT
GET {{baseUrl}}/api/v1/quotations/{{quoId}}
Authorization: Bearer {{salesToken}}

> {%
client.test("quotation status after admin approval", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.data.status === "WAITING_CLIENT", "quotation status must be WAITING_CLIENT");
});
%}

### [2-10] Notification 조회 (CLIENT) - 다음 승인 요청 알림 확인
GET {{baseUrl}}/api/v1/notifications?page=0&size=20
Authorization: Bearer {{clientToken}}

> {%
client.test("client notification for quotation approval request exists", function () {
  client.assert(response.status === 200, "status must be 200");
  const items = response.body.data.content || [];
  client.assert(items.some((item) => item.type === "APPROVAL_REQUESTED"), "client approval requested notification must exist");
});
%}

### [2-11] QUO 거래처 최종 승인
POST {{baseUrl}}/api/v1/approvals/{{quoApprovalId}}/steps/{{quoClientStepId}}/decision
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "decision": "APPROVE",
  "reason": "거래처 승인"
}

> {%
client.test("quotation client approval success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.data.status === "APPROVED", "approval request must be APPROVED");
});
%}

### [2-12] QUO 최종 상태 확인
GET {{baseUrl}}/api/v1/quotations/{{quoId}}
Authorization: Bearer {{salesToken}}

> {%
client.test("quotation final status approved", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.data.status === "FINAL_APPROVED", "quotation status must be FINAL_APPROVED");
});
%}

### [2-13] Notification 조회 (SALES_REP) - 승인 완료 알림 확인
GET {{baseUrl}}/api/v1/notifications?page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("sales notification for quotation approval completed exists", function () {
  client.assert(response.status === 200, "status must be 200");
  const items = response.body.data.content || [];
  client.assert(items.some((item) => item.type === "APPROVAL_COMPLETED"), "APPROVAL_COMPLETED notification must exist");
});
%}

