### [3-1] CNT 생성 (SALES_REP)
POST {{baseUrl}}/api/v1/contracts
Authorization: Bearer {{salesToken}}
Content-Type: application/json

{
  "quotationId": {{quoId}},
  "clientId": {{clientId}},
  "startDate": "2026-03-01",
  "endDate": "2027-03-31",
  "billingCycle": "MONTHLY",
  "specialTerms": "월말 정산 runId={{runId}}",
  "memo": "시나리오1 계약서 runId={{runId}}",
  "items": [
    {
      "productId": {{watermelonProductId}},
      "productName": "{{watermelonProductName}}",
      "productCategory": "수박",
      "totalQuantity": 20,
      "unit": "{{watermelonProductUnit}}",
      "unitPrice": {{watermelonProductPrice}}
    },
    {
      "productId": {{melonProductId}},
      "productName": "{{melonProductName}}",
      "productCategory": "참외",
      "totalQuantity": 15,
      "unit": "{{melonProductUnit}}",
      "unitPrice": {{melonProductPrice}}
    }
  ]
}

> {%
client.test("contract create success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### [3-2] DealLog에서 CNT ID 조회
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=200&sort=actionAt,desc
Authorization: Bearer {{salesToken}}

> {%
client.test("deal log contains latest CNT create", function () {
  client.assert(response.status === 200, "status must be 200");
});
const logs = response.body.data.content || [];
const cntCreateLogs = logs.filter((log) => log.docType === "CNT" && log.actionType === "CREATE");
client.assert(cntCreateLogs.length > 0, "CNT CREATE log must exist");
client.global.set("cntId", cntCreateLogs[cntCreateLogs.length - 1].refId);
