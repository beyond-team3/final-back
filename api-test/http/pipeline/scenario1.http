### ============================================================
### SECTION 7. 전체 타임라인 / Schedule / Statistics 최종 확인
### ============================================================

### [7-1] Deal 전체 타임라인 조회
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=300&sort=actionAt,asc
Authorization: Bearer {{salesToken}}

> {%
client.test("full deal timeline contains RFQ->QUO->CNT->ORD->STMT->INV->PAY", function () {
  client.assert(response.status === 200, "status must be 200");
  const logs = response.body.data.content || [];
  const required = [
    { docType: "RFQ", refId: Number(client.global.get("rfqId")) },
    { docType: "QUO", refId: Number(client.global.get("quoId")) },
    { docType: "CNT", refId: Number(client.global.get("cntId")) },
    { docType: "ORD", refId: Number(client.global.get("ordId")) },
    { docType: "STMT", refId: Number(client.global.get("stmtId")) },
    { docType: "INV", refId: Number(client.global.get("invId")) },
    { docType: "PAY", refId: Number(client.global.get("payId")) }
  ];
  let lastIndex = -1;
  required.forEach((item) => {
    const idx = logs.findIndex((log) => log.docType === item.docType && log.refId === item.refId);
    client.assert(idx > lastIndex, item.docType + " must appear in chronological order for current run");
    lastIndex = idx;
  });
});
%}

### [7-2] Client 기준 타임라인 조회
GET {{baseUrl}}/api/v1/clients/{{clientId}}/logs?page=0&size=100&sort=actionAt,asc
Authorization: Bearer {{adminToken}}

> {%
client.test("client timeline contains full pipeline", function () {
  client.assert(response.status === 200, "status must be 200");
  const logs = response.body.data.content || [];
  [
    ["RFQ", Number(client.global.get("rfqId"))],
    ["QUO", Number(client.global.get("quoId"))],
    ["CNT", Number(client.global.get("cntId"))],
    ["ORD", Number(client.global.get("ordId"))],
    ["STMT", Number(client.global.get("stmtId"))],
    ["INV", Number(client.global.get("invId"))],
    ["PAY", Number(client.global.get("payId"))]
  ].forEach(([docType, refId]) => {
    client.assert(logs.some((log) => log.docType === docType && log.refId === refId), docType + " must exist in client timeline for current run");
  });
});
%}

### [7-3] 전체 Schedule 조회
GET {{baseUrl}}/api/v1/schedules?from=2026-01-01T00:00:00&to=2027-12-31T23:59:59&includeDeal=true&includePersonal=false
Authorization: Bearer {{salesToken}}

> {%
