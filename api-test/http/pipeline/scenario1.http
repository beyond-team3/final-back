### [0-7] CLIENT 등록
POST {{baseUrl}}/api/v1/accounts/clients/register
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "clientName": "시나리오 농산유통",
  "clientBrn": "123-45-67890",
  "ceoName": "홍길동",
  "companyPhone": "02-1234-5678",
  "address": "서울특별시 송파구 올림픽로 300, 05551",
  "clientType": "DISTRIBUTOR",
  "managerName": "김거래",
  "managerPhone": "010-3333-4444",
  "managerEmail": "{{clientEmail}}",
  "totalCredit": 50000000,
  "employeeId": {{salesEmployeeId}}
}

> {%
client.test("client register success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
  client.assert(!!response.body.data.id, "clientId must exist");
});
client.global.set("clientId", response.body.data.id);
%}

