### ============================================================
### SECTION 7. 전체 타임라인 / Schedule / Statistics 최종 확인
### ============================================================

### [7-1] Deal 전체 타임라인 조회
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=100&sort=actionAt,asc
Authorization: Bearer {{salesToken}}

> {%
client.test("full deal timeline contains RFQ->QUO->CNT->ORD->STMT->INV->PAY", function () {
  client.assert(response.status === 200, "status must be 200");
  const docs = (response.body.data.content || []).map((log) => log.docType);
  const required = ["RFQ", "QUO", "CNT", "ORD", "STMT", "INV", "PAY"];
  let lastIndex = -1;
  required.forEach((docType) => {
    const idx = docs.indexOf(docType);
    client.assert(idx > lastIndex, docType + " must appear in chronological order");
    lastIndex = idx;
  });
});
%}

### [7-2] Client 기준 타임라인 조회
GET {{baseUrl}}/api/v1/clients/{{clientId}}/logs?page=0&size=100&sort=actionAt,asc
Authorization: Bearer {{adminToken}}

> {%
client.test("client timeline contains full pipeline", function () {
  client.assert(response.status === 200, "status must be 200");
  const docs = new Set((response.body.data.content || []).map((log) => log.docType));
  ["RFQ", "QUO", "CNT", "ORD", "STMT", "INV", "PAY"].forEach((docType) => {
    client.assert(docs.has(docType), docType + " must exist in client timeline");
  });
});
%}

### [7-3] 전체 Schedule 조회
GET {{baseUrl}}/api/v1/schedules?from=2026-01-01T00:00:00&to=2027-12-31T23:59:59&includeDeal=true&includePersonal=false
Authorization: Bearer {{salesToken}}

> {%
client.test("schedule contains implemented pipeline events", function () {
  client.assert(response.status === 200, "status must be 200");
  const eventTypes = new Set((response.body.data || []).filter((item) => item.dealId === Number(client.global.get("dealId"))).map((item) => item.eventType));
  ["DOC_APPROVED", "DELIVERY_DUE", "PAYMENT_DUE", "PAYMENT_RECEIVED"].forEach((eventType) => {
    client.assert(eventTypes.has(eventType), eventType + " must exist");
  });
});
%}

