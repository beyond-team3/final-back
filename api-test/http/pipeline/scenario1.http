### SeedFlow+ 시나리오1: 전체 파이프라인 연쇄 검증
### 기존 데이터가 있어도 실행 가능하도록 고유 식별자(runId) 기반으로 검증
### 실행 순서: SECTION 0 → 1 → 2 → 3 → 4 → 5 → 6 → 7
### 환경: local (http-client.env.json 참조)
###
### 주의 1) 실제 구현 기준으로 사전 생성/활성화된 ADMIN 계정이 필요하다.
### 주의 2) 실제 권한 흐름은 RFQ/ORD/PAY=CLIENT, QUO/CNT/INV=SALES_REP, QUO/CNT 승인=ADMIN→CLIENT 2단계다.
### 주의 3) Schedule 검증은 현재 구현 enum 기준(eventType=DOC_APPROVED/DELIVERY_DUE/PAYMENT_DUE/PAYMENT_RECEIVED, docType=CONTRACT/ORDER/INVOICE/PAYMENT)으로 수행한다.

@baseUrl = http://localhost:8080
@adminEmail = admin@seedflow.com
@adminPassword = password1234!
@salesEmail = sales@seedflow.com
@salesPassword = password1234!
@clientEmail = client2@seedflow.com
@clientPassword = password1234!

### local

### ============================================================
### SECTION 0. 계정/기초 데이터 준비
### ============================================================

### [0-1] ADMIN 로그인
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{adminEmail}}",
  "loginPw": "{{adminPassword}}"
}

> {%
client.test("ADMIN login success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
  client.assert(!!response.body.data.accessToken, "admin access token must exist");
});
client.global.set("adminToken", response.body.data.accessToken);
client.global.set("runId", String(Date.now()));
%}

### [0-2] SALES_REP 사원 ID 조회
GET {{baseUrl}}/api/v1/accounts/employees
Authorization: Bearer {{adminToken}}

> {%
client.test("sales employee list success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const salesCandidates = response.body.data || [];
const employee = salesCandidates.find((item) =>
  item.employeeEmail === "sales@seedflow.com" ||
  item.employeeName === "영업담당자"
) || salesCandidates.find((item) => item.employeeEmail !== "admin@seedflow.com");
client.assert(!!employee, "sales employee must exist");
client.global.set("salesEmployeeId", employee.employeeId);
%}

### [0-3] SALES_REP 계정 ID 조회
GET {{baseUrl}}/api/v1/accounts/employees/{{salesEmployeeId}}
Authorization: Bearer {{adminToken}}

> {%
client.test("sales employee detail success", function () {
  client.assert(response.status === 200, "status must be 200");
});
client.assert(!!response.body.data.accountId, "sales accountId must exist");
client.global.set("salesAccountId", response.body.data.accountId);
%}

### [0-4] CLIENT ID 조회
GET {{baseUrl}}/api/v1/accounts/clients
Authorization: Bearer {{adminToken}}

> {%
client.test("client list success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const clientCandidates = response.body.data || [];
const clientItem = clientCandidates.find((item) =>
  item.clientName === "시드플로우 거래처2" ||
  item.managerName === "거래처담당자2" ||
  item.managerEmail === "client2@seedflow.com"
) || clientCandidates[0];
client.assert(!!clientItem, "client must exist");
client.global.set("clientId", clientItem.id);
%}

### [0-5] CLIENT 계정 ID 조회
GET {{baseUrl}}/api/v1/accounts/clients/{{clientId}}
Authorization: Bearer {{adminToken}}

> {%
client.test("client detail success", function () {
  client.assert(response.status === 200, "status must be 200");
});
client.assert(!!response.body.data.accountId, "client accountId must exist");
client.global.set("clientAccountId", response.body.data.accountId);
%}

### [0-6] SALES_REP 로그인
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{salesEmail}}",
  "loginPw": "{{salesPassword}}"
}

> {%
client.test("SALES_REP login success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(!!response.body.data.accessToken, "sales access token must exist");
});
client.global.set("salesToken", response.body.data.accessToken);
%}

### [0-7] CLIENT 로그인
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{clientEmail}}",
  "loginPw": "{{clientPassword}}"
}

> {%
client.test("CLIENT login success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(!!response.body.data.accessToken, "client access token must exist");
});
client.global.set("clientToken", response.body.data.accessToken);
%}

### [0-8] 수박 상품 조회
GET {{baseUrl}}/api/v1/products?category=WATERMELON&limit=100
Authorization: Bearer {{adminToken}}

> {%
client.test("watermelon product lookup success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const watermelonProducts = response.body || [];
const watermelonProduct = watermelonProducts
  .filter((item) => item.category === "WATERMELON" && item.priceData && item.name)
  .reduce((latest, item) => {
    if (!latest) return item;
    return Number(item.id) > Number(latest.id) ? item : latest;
  }, null);
client.assert(!!watermelonProduct, "usable watermelon product must exist");
client.global.set("watermelonProductId", watermelonProduct.id);
client.global.set("watermelonProductName", watermelonProduct.name);
client.global.set("watermelonProductUnit", watermelonProduct.priceData.unit);
client.global.set("watermelonProductPrice", watermelonProduct.priceData.price);
%}

### [0-9] 참외 상품 조회
GET {{baseUrl}}/api/v1/products?category=MELON&limit=100
Authorization: Bearer {{adminToken}}

> {%
client.test("melon product lookup success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const melonProducts = response.body || [];
const melonProduct = melonProducts
  .filter((item) => item.category === "MELON" && item.priceData && item.name)
  .reduce((latest, item) => {
    if (!latest) return item;
    return Number(item.id) > Number(latest.id) ? item : latest;
  }, null);
client.assert(!!melonProduct, "usable melon product must exist");
client.global.set("melonProductId", melonProduct.id);
client.global.set("melonProductName", melonProduct.name);
client.global.set("melonProductUnit", melonProduct.priceData.unit);
client.global.set("melonProductPrice", melonProduct.priceData.price);
%}

### ============================================================
### SECTION 1. RFQ
### ============================================================

### [1-1] RFQ 생성 (CLIENT)
POST {{baseUrl}}/api/v1/requests
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "requirements": "2026년 봄 시즌 판촉용 RFQ runId={{runId}}",
  "items": [
    {
      "productId": {{watermelonProductId}},
      "productCategory": "수박",
      "productName": "{{watermelonProductName}}",
      "quantity": 20
    },
    {
      "productId": {{melonProductId}},
      "productCategory": "참외",
      "productName": "{{melonProductName}}",
      "quantity": 15
    }
  ]
}

> {%
client.test("RFQ create success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### [1-2] RFQ ID 조회
GET {{baseUrl}}/api/v1/requests/pending
Authorization: Bearer {{salesToken}}

> {%
client.test("pending RFQ list success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const pendingRequests = response.body.data || [];
client.assert(pendingRequests.length > 0, "pending rfq must exist");
const latestRfq = pendingRequests.reduce((latest, item) => {
  if (!latest) return item;
  return Number(item.id) > Number(latest.id) ? item : latest;
}, null);
client.assert(!!latestRfq, "latest pending rfq must exist");
client.global.set("rfqId", latestRfq.id);
%}

### [1-3] Deal ID 조회
GET {{baseUrl}}/api/v1/deals?clientId={{clientId}}&latestDocType=RFQ&page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("deal list for RFQ success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const deal = (response.body.data.content || []).find((item) => item.latestRefId === Number(client.global.get("rfqId")));
client.assert(!!deal, "deal linked to rfq must exist");
client.global.set("dealId", deal.dealId);
%}

### [1-4] Deal 기준 DealLog 조회
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=100&sort=actionAt,desc
Authorization: Bearer {{salesToken}}

> {%
client.test("deal log contains RFQ create", function () {
  client.assert(response.status === 200, "status must be 200");
  const logs = response.body.data.content || [];
  client.assert(logs.some((log) => log.docType === "RFQ" && log.refId === Number(client.global.get("rfqId")) && log.actionType === "CREATE"), "RFQ CREATE log must exist");
});
%}

### [1-5] 문서 기준 DealLog 조회
GET {{baseUrl}}/api/v1/deal-logs?docType=RFQ&refId={{rfqId}}&page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("document log for RFQ exists", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert((response.body.data.content || []).length > 0, "RFQ document log must exist");
});
%}

### [1-6] Notification 조회 (SALES_REP)
GET {{baseUrl}}/api/v1/notifications?page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("sales notification after RFQ exists", function () {
  client.assert(response.status === 200, "status must be 200");
});
%}

