### ============================================================
### SECTION 1. RFQ
### ============================================================

### [1-1] RFQ 생성 (CLIENT)
POST {{baseUrl}}/api/v1/requests
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "requirements": "2026년 봄 시즌 판촉용 RFQ",
  "items": [
    {
      "productId": {{watermelonProductId}},
      "productCategory": "수박",
      "productName": "프리미엄 수박 5kg",
      "quantity": 20
    },
    {
      "productId": {{melonProductId}},
      "productCategory": "참외",
      "productName": "고당도 참외 3kg",
      "quantity": 15
    }
  ]
}

> {%
client.test("RFQ create success", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert(response.body.result === "SUCCESS", "result must be SUCCESS");
});
%}

### [1-2] RFQ ID 조회
GET {{baseUrl}}/api/v1/requests/pending
Authorization: Bearer {{salesToken}}

> {%
client.test("pending RFQ list success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const rfq = (response.body.data || []).find((item) => item.clientName === "시나리오 농산유통");
client.assert(!!rfq, "rfq must exist");
client.global.set("rfqId", rfq.id);
%}

### [1-3] Deal ID 조회
GET {{baseUrl}}/api/v1/deals?clientId={{clientId}}&latestDocType=RFQ&page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("deal list for RFQ success", function () {
  client.assert(response.status === 200, "status must be 200");
});
const deal = (response.body.data.content || []).find((item) => item.latestRefId === Number(client.global.get("rfqId")));
client.assert(!!deal, "deal linked to rfq must exist");
client.global.set("dealId", deal.dealId);
%}

### [1-4] Deal 기준 DealLog 조회
GET {{baseUrl}}/api/v1/deals/{{dealId}}/logs?page=0&size=20&sort=actionAt,asc
Authorization: Bearer {{salesToken}}

> {%
client.test("deal log contains RFQ create", function () {
  client.assert(response.status === 200, "status must be 200");
  const logs = response.body.data.content || [];
  client.assert(logs.some((log) => log.docType === "RFQ" && log.refId === Number(client.global.get("rfqId")) && log.actionType === "CREATE"), "RFQ CREATE log must exist");
});
%}

### [1-5] 문서 기준 DealLog 조회
GET {{baseUrl}}/api/v1/deal-logs?docType=RFQ&refId={{rfqId}}&page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("document log for RFQ exists", function () {
  client.assert(response.status === 200, "status must be 200");
  client.assert((response.body.data.content || []).length > 0, "RFQ document log must exist");
});
%}

### [1-6] Notification 조회 (SALES_REP)
GET {{baseUrl}}/api/v1/notifications?page=0&size=20
Authorization: Bearer {{salesToken}}

> {%
client.test("sales notification after RFQ exists", function () {
  client.assert(response.status === 200, "status must be 200");
  const items = response.body.data.content || [];
  client.assert(items.some((item) => item.type === "DEAL_STATUS_CHANGED" || item.type === "QUOTATION_REQUEST_CREATED"), "RFQ related notification must exist");
});
%}

